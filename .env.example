###############################################################################
# Recruitment Intelligence Platform
# Environment Configuration
###############################################################################

APP_NAME=Recruitment Intelligence Platform
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True

###############################################################################
# API
###############################################################################

API_V1_PREFIX=/api/v1
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY
ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

###############################################################################
# DATABASE
###############################################################################

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/recruitment_intelligence

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=recruitment_intelligence
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

###############################################################################
# REDIS
###############################################################################

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

###############################################################################
# CELERY
###############################################################################

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

###############################################################################
# CORS
###############################################################################

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

###############################################################################
# LOGGING
###############################################################################

LOG_LEVEL=INFO
LOG_FORMAT=text

###############################################################################
# FILE STORAGE
###############################################################################

UPLOAD_DIRECTORY=storage/uploads
TEMP_DIRECTORY=storage/temp
MAX_UPLOAD_SIZE_MB=25

###############################################################################
# AI SETTINGS
###############################################################################

DEFAULT_EMBEDDING_MODEL=
DEFAULT_LLM_MODEL=
OPENAI_API_KEY=

###############################################################################
# EMAIL
###############################################################################

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=True

###############################################################################
# GOOGLE
###############################################################################

GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SHEETS_ID=

###############################################################################
# SECURITY
###############################################################################

PASSWORD_MIN_LENGTH=8
BCRYPT_ROUNDS=12

###############################################################################
# FEATURE FLAGS
###############################################################################

ENABLE_REGISTRATION=False
ENABLE_SWAGGER=True
ENABLE_BACKGROUND_TASKS=True
ENABLE_RATE_LIMITING=False
